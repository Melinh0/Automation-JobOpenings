# Credenciais do Gupy (preencha com seus dados)
GUPY_EMAIL=seu_email@example.com
GUPY_PASSWORD=sua_senha

# Dados pessoais (para preenchimento automático de formulários)
NOME_COMPLETO=Seu Nome Completo
NOME_MAE=Nome da sua mãe
NOME_PAI=Nome do seu pai
CPF=00000000000
RG=00000000
TELEFONE=(00) 00000-0000
LINKEDIN=https://www.linkedin.com/in/seu-perfil/
GITHUB=https://github.com/seu-usuario

# API Ollama (obtenha em https://ollama.com)
OLLAMA_API_KEY=sua_api_key
OLLAMA_HOST=https://ollama.com

# Configurações do bot (ajuste conforme necessário)
KEYWORDS=Segurança, Python, dados, Engenheiro de dados, IA, BI, Automação, estagiário backend, cientista, JR, desenvolvedor, analista, backend
GUPY_SEARCH_URL=https://portal.gupy.io/job-search/sortBy=publishedDate
CV_PDF_PATH=caminho/para/seu/curriculo.pdf